<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yash Event Management</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI;
}

body{
background:#f5f5f5;
scroll-behavior:smooth;
}

/* Navbar */

header{
position:fixed;
width:100%;
background:#111;
color:white;
padding:15px 40px;
display:flex;
justify-content:space-between;
align-items:center;
z-index:1000;
}

header h2{
letter-spacing:1px;
}

nav a{
color:white;
margin-left:20px;
text-decoration:none;
font-weight:500;
}

nav a:hover{
color:#ff4d4d;
}

/* Hero */

.hero{
height:100vh;
background:url("https://images.unsplash.com/photo-1511795409834-ef04bbd61622") center/cover;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
color:white;
padding:20px;
}

.hero h1{
font-size:50px;
margin-bottom:10px;
}

.hero p{
font-size:20px;
margin-bottom:20px;
}

.btn{
background:#ff4d4d;
color:white;
padding:12px 25px;
border:none;
border-radius:5px;
cursor:pointer;
font-size:16px;
}

.btn:hover{
background:#e63b3b;
}

/* Sections */

section{
padding:80px 10%;
text-align:center;
}

section h2{
margin-bottom:40px;
font-size:35px;
}

/* Services */

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
transition:0.3s;
}

.card:hover{
transform:translateY(-10px);
}

/* Gallery */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:15px;
}

.gallery img{
width:100%;
border-radius:10px;
transition:0.3s;
}

.gallery img:hover{
transform:scale(1.05);
}

/* Contact */

form{
max-width:500px;
margin:auto;
}

input,textarea{
width:100%;
padding:12px;
margin:10px 0;
border:1px solid #ccc;
border-radius:5px;
}

/* Footer */

footer{
background:#111;
color:white;
text-align:center;
padding:20px;
margin-top:40px;
}

/* Responsive */

@media(max-width:768px){

.hero h1{
font-size:35px;
}

}

</style>
</head>

<body>

<header>

<h2>Yash Events</h2>

<nav>
<a href="#home">Home</a>
<a href="#about">About</a>
<a href="#services">Services</a>
<a href="#gallery">Gallery</a>
<a href="#contact">Contact</a>
</nav>

</header>

<!-- Hero -->

<section class="hero" id="home">

<h1>Yash Event Management</h1>

<p>We Make Your Events Beautiful & Memorable</p>

<button class="btn" onclick="scrollContact()">Book Event</button>

</section>

<!-- About -->

<section id="about">

<h2>About Us</h2>

<p>

Yash Event Management provides complete event planning services including

weddings, birthday parties, corporate events and special celebrations.

Our team ensures creative decoration and perfect event organization.

</p>

</section>

<!-- Services -->

<section id="services">

<h2>Our Services</h2>

<div class="services">

<div class="card">
<h3>Wedding Events</h3>
<p>Full wedding planning, decoration and venue management.</p>
</div>

<div class="card">
<h3>Birthday Parties</h3>
<p>Creative birthday themes and fun party arrangements.</p>
</div>

<div class="card">
<h3>Corporate Events</h3>
<p>Professional meetings, conferences and corporate functions.</p>
</div>

<div class="card">
<h3>Stage Decoration</h3>
<p>Luxury stage and lighting decoration for events.</p>
</div>

</div>

</section>

<!-- Gallery -->

<section id="gallery">

<h2>Event Gallery</h2>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf">
<img src="https://images.unsplash.com/photo-1505236858219-8359eb29e329">
<img src="https://images.unsplash.com/photo-1511578314322-379afb476865">
<img src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622">

</div>

</section>

<!-- Contact -->

<section id="contact">

<h2>Book Your Event</h2>

<form onsubmit="submitForm(event)">

<input type="text" placeholder="Your Name" required>

<input type="email" placeholder="Your Email" required>

<textarea rows="5" placeholder="Event Details"></textarea>

<button class="btn">Submit</button>

</form>

</section>

<footer>

<p>© 2026 Yash Event Management | All Rights Reserved</p>

</footer>

<script>

/* Scroll to contact */

function scrollContact(){

document.getElementById("contact").scrollIntoView({

behavior:"smooth"

});

}

/* Form */

function submitForm(e){

e.preventDefault();

alert("Thank you! Your event request has been sent.");

}

</script>

</body>
</html>
